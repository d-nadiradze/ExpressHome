# === Docker Compose Environment ===
# These variables are used by docker-compose.yml

# MySQL
MYSQL_ROOT_PASSWORD=change-this-strong-root-password
MYSQL_PASSWORD=change-this-strong-app-password

# App
APP_URL=https://makler.solutions

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=generate-a-strong-random-secret-here

# Encryption key for myhome passwords (exactly 32 chars)
ENCRYPTION_KEY=change-this-to-exactly-32-chars!

# Google OAuth (per-user Sheets access)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://makler.solutions/api/google/auth/callback

# === Deployment Instructions ===
#
# 1. Copy this file to .env on your VPS:
#    cp .env.production.example .env
#
# 2. Replace ALL placeholder values with real secrets
#
# 3. Replace "makler.solutions" in nginx/default.conf with your actual domain
#
# 4. Start the stack:
#    docker compose up -d
#
# 5. Run database migrations:
#    docker compose exec app npx prisma db push
#
# 6. Set up SSL (after DNS is pointing to your server):
#    chmod +x deploy/setup-ssl.sh
#    ./deploy/setup-ssl.sh your-email@example.com
#
#    This requests a Let's Encrypt certificate and switches nginx to HTTPS.
#    Update APP_URL and GOOGLE_OAUTH_REDIRECT_URI to https://makler.solutions in .env
#
# 7. View logs:
#    docker compose logs -f app
#
# 8. Rebuild after code changes:
#    docker compose up -d --build app
