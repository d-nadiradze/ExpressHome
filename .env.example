# Database (MySQL)
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/myhome_parser"

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-here"

# Encryption key for myhome passwords (exactly 32 chars)
ENCRYPTION_KEY="your-32-char-encryption-key-here"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Session duration in seconds (default: 24 hours)
SESSION_DURATION=86400

# Listing prices are read in USD via myhome.ge's on-page currency toggle (not NBG math).

# Google OAuth (per-user Sheets access)
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/google/auth/callback"
