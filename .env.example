# Database (MySQL)
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/myhome_parser"

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-here"

# Encryption key for myhome passwords (exactly 32 chars)
ENCRYPTION_KEY="your-32-char-encryption-key-here"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Session duration in seconds (default: 24 hours)
SESSION_DURATION=86400

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_DESCRIPTION_TEMPLATE_FALLBACK=true

# Google OAuth (per-user Sheets access)
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/google/auth/callback"

# Redis (BullMQ job queue + prefill progress). Start with: npm run redis:up
REDIS_URL="redis://localhost:6379"

# Prefill/parse workers (run in a second terminal: npm run worker:dev)
# PREFILL_MAX_CONCURRENT=3
# PARSE_MAX_CONCURRENT=3

# API prefill (HTTP — recommended; browser fallback if API fails)
# MYHOME_API_PREFILL=true
# MYHOME_API_PREFILL_FALLBACK=true
# MYHOME_PREFILL_HEADLESS=true
# MYHOME_AUTO_PUBLISH=true
# SSGE_API_PREFILL=true
# SSGE_API_PREFILL_FALLBACK=true
# SSGE_PREFILL_HEADLESS=true
# SSGE_AUTO_PUBLISH=true
