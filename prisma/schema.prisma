generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String?
  role          Role           @default(USER)
  isActive      Boolean        @default(true)
  aiTokenLimitHour   Int?
  aiTokenLimitDay    Int?
  aiTokenLimitMonth  Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  session       Session?
  myhomeAccount MyhomeAccount?
  ssgeAccount   SsgeAccount?
  googleAccount GoogleAccount?
  parsedListings ParsedListing[]
  aiTokenUsage  AiTokenUsage[]

  @@map("users")
}

model GoogleAccount {
  id                 String   @id @default(cuid())
  userId             String   @unique
  googleEmail        String
  accessToken        String   @db.Text
  refreshToken       String   @db.Text
  tokenExpiryDate    DateTime?
  defaultSpreadsheetId String? @db.VarChar(255)
  defaultSheetTab    String?  @db.VarChar(120)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_accounts")
}

// One active session per user (userId is unique)
model Session {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique @db.VarChar(512)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model MyhomeAccount {
  id               String   @id @default(cuid())
  userId           String   @unique
  myhomeEmail      String
  myhomePassword   String   @db.Text  // AES-256 encrypted
  isVerified       Boolean  @default(false)
  lastLoginAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("myhome_accounts")
}

model SsgeAccount {
  id              String    @id @default(cuid())
  userId          String    @unique
  ssgeEmail       String
  ssgePassword    String    @db.Text  // AES-256 encrypted
  accessToken     String?   @db.Text  // encrypted Bearer JWT for api-gateway
  tokenExpiryDate DateTime?
  isVerified      Boolean   @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ssge_accounts")
}

model ParsedListing {
  id             String   @id @default(cuid())
  userId         String
  sourceUrl      String   @db.VarChar(1024)
  title          String?

  // Property classification
  propertyType   String?  // ბინა, კერძო სახლი, აგარაკი, მიწის ნაკვეთი, კომერციული ფართი, სასტუმრო
  dealType       String?  // იყიდება, ქირავდება, გირავდება, ქირავდება დღიურად
  buildingStatus String?  // ძველი აშენებული, ახალი აშენებული, მშენებარე
  condition      String?  // ახალი გარემონტებული, სარემონტო, თეთრი კარკასი, etc.

  // Location
  city           String?
  address        String?
  street         String?
  streetNumber   String?
  cadastralCode  String?

  // Pricing
  price          String?
  pricePerSqm    String?
  currency       String?

  // Specs
  area           String?
  rooms          String?
  bedrooms       String?
  floor          String?
  totalFloors    String?
  projectType    String?  // არასტანდარტული, etc.

  // Extras
  bathrooms      String?  // სველი წერტილი
  balconyArea    String?
  verandaArea    String?
  loggiaArea     String?

  // Content
  description    String?  @db.LongText
  images         Json?    // array of image URLs
  rawData        Json?    // full scraped data object

  postStatus     PostStatus @default(PENDING)
  postUrl        String?  // URL of created post on myhome.ge
  ssgePostStatus PostStatus @default(PENDING)
  ssgePostUrl    String?  // URL of created post on ss.ge
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("parsed_listings")
}

enum PostStatus {
  PARSING
  PENDING
  POSTED
  FAILED
}

model AiTokenUsage {
  id               String   @id @default(cuid())
  userId           String
  totalTokens      Int
  promptTokens     Int?
  completionTokens Int?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("ai_token_usage")
}
